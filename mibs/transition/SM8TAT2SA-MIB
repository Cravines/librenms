    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "An entry in the sm8tat2saIPInterfacesTable."
    INDEX { sm8tat2saIPInterfacesIndex }
    ::= { sm8tat2saIPInterfacesTable 1 }

SM8TAT2SAIPInterfacesEntry ::=
    SEQUENCE {
        sm8tat2saIPInterfacesIndex Integer32,
        sm8tat2saIPInterfacesVLAN Integer32,
        sm8tat2saIPInterfacesIPv4DHCPEnable Integer32,
        sm8tat2saIPInterfacesIPv4DHCPFallback Integer32,
        sm8tat2saIPInterfacesIPv4DHCPCurrentLease DisplayString,
        sm8tat2saIPInterfacesIPv4Address DisplayString,
        sm8tat2saIPInterfacesIPv4Mask Integer32,
        sm8tat2saIPInterfacesIPv6Address DisplayString,
        sm8tat2saIPInterfacesIPv6Mask Integer32,
        sm8tat2saIPInterfacesRowStatus RowStatus
    }

sm8tat2saIPInterfacesIndex OBJECT-TYPE
   SYNTAX Integer32 (1..128)
   MAX-ACCESS not-accessible
   STATUS current
   DESCRIPTION
       "Interface Table Index"
   ::= { sm8tat2saIPInterfacesEntry 1 }

sm8tat2saIPInterfacesVLAN OBJECT-TYPE
   SYNTAX Integer32 (1..4095)
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "VLAN ID for interface, range: 1-4095.
        If you add a new VLAN ID here, you also need to set IPInterfacesIPv4Address, IPInterfacesIPv4Mask, or IPInterfacesIPv6Address, IPInterfacesIPv6Mask."
   ::= { sm8tat2saIPInterfacesEntry 2 }

sm8tat2saIPInterfacesIPv4DHCPEnable OBJECT-TYPE
   SYNTAX Integer32 (0|1)
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv4 DHCP Setting for interface.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv4DHCP to an empty entry in table.
        default:0
        0: disable
        1: enable"
   ::= { sm8tat2saIPInterfacesEntry 3 }

sm8tat2saIPInterfacesIPv4DHCPFallback OBJECT-TYPE
   SYNTAX Integer32
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv4 DHCP fallbcak. range: 1-4294967295 seconds.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv4DHCPFallback to an empty entry in table.
        Please enable IPInterfacesIPv4DHCP first if you want to set IPInterfacesIPv4DHCPFallback."
   ::= { sm8tat2saIPInterfacesEntry 4 }

sm8tat2saIPInterfacesIPv4DHCPCurrentLease OBJECT-TYPE
   SYNTAX DisplayString
   MAX-ACCESS read-only
   STATUS current
   DESCRIPTION
       "IPv4 DHCP Current Lease Address for interface."
   ::= { sm8tat2saIPInterfacesEntry 5 }

sm8tat2saIPInterfacesIPv4Address OBJECT-TYPE
   SYNTAX DisplayString
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv4 address for interface.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv4Address to an empty entry in table.
        If you set IPInterfacesIPv4Address, please also set IPInterfacesIPv4Mask.
        If you set IPInterfacesIPv4Address and not set IPInterfacesIPv4Mask before, it will be set to value default 24."
   ::= { sm8tat2saIPInterfacesEntry 6 }

sm8tat2saIPInterfacesIPv4Mask OBJECT-TYPE
   SYNTAX Integer32 (1..32)
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv4 mask for interface.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv4Mask to an empty entry in table.
        Please set IPInterfacesIPv4Address first and then set IPInterfacesIPv4Mask."
   ::= { sm8tat2saIPInterfacesEntry 7 }

sm8tat2saIPInterfacesIPv6Address OBJECT-TYPE
   SYNTAX DisplayString (SIZE (0..30))
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv6 address for interface.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv6Address to an empty entry in table.
        If you set IPInterfacesIPv6Address, please also set IPInterfacesIPv6Mask.
        If you set IPInterfacesIPv6Address and not set IPInterfacesIPv6Mask before, it will be set to value default 64."
   ::= { sm8tat2saIPInterfacesEntry 8 }

sm8tat2saIPInterfacesIPv6Mask OBJECT-TYPE
   SYNTAX Integer32 (1..128)
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "IPv6 mask for interface.
        Please add IPInterfacesVLAN first if you want to set IPInterfacesIPv6Mask to an empty entry in table.
        Please set IPInterfacesIPv6Address first and then set IPInterfacesIPv6Mask."
   ::= { sm8tat2saIPInterfacesEntry 9 }

sm8tat2saIPInterfacesRowStatus OBJECT-TYPE
   SYNTAX RowStatus
   MAX-ACCESS read-create
   STATUS current
   DESCRIPTION
       "This object indicates the status of this entry, and is
        used to create/delete entries. Any object in an entry of
        this table may be modified while the value of the
        corresponding instance of this object is active(1).
        notReady(3) and createAndGo(4) not supported."
