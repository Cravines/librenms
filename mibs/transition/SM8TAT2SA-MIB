sm8tat2saIP OBJECT IDENTIFIER ::= { sm8tat2saSystem 4 }

sm8tat2saIPConfiguration OBJECT IDENTIFIER ::= { sm8tat2saIP 1 }

sm8tat2saDNSServerMode OBJECT-TYPE
   SYNTAX INTEGER {noDNSServer(0), configured(1), fromThisDHCPInterface(2), fromAnyDHCPInterface(3)}
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
       "DNS Server Mode.
        0: No DNS Server
        1: Configured
        2: From this DHCP interface
        3: From any DHCP interfaces
        If set: 1:Configured, please also set IPV4 or IPv6 address to DNSServerValueIPVLAN.
        If set: 2:From this DHCP interface, it will set DNSServerValueIPVLAN to VLAN 1 for default, please set it to your value."
   ::= { sm8tat2saIPConfiguration 1 }

sm8tat2saDNSServerIPAddress OBJECT-TYPE
   SYNTAX DisplayString
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
       "DNS IPv4/IPv6 Address.
        For set IPv4/IPv6 Address, please set DNSServerMode to : 1:Configured first."
   ::= { sm8tat2saIPConfiguration 2 }

sm8tat2saDNSServerVLAN OBJECT-TYPE
   SYNTAX Integer32 (1..4095)
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
       "VLAN value.
        For set VLAN value, please set DNSServerMode to : 2:From this DHCP interface first.
        For set VLAN value, please set an interface with IPv4 DHCP enable. And then set VLAN to it."
   ::= { sm8tat2saIPConfiguration 3 }

sm8tat2saIPInterfacesTable OBJECT-TYPE
   SYNTAX SEQUENCE OF SM8TAT2SAIPInterfacesEntry
   MAX-ACCESS not-accessible
   STATUS current
   DESCRIPTION
       "A table of IP interface for switch."
    ::= { sm8tat2saIPConfiguration 4 }

sm8tat2saIPInterfacesEntry OBJECT-TYPE
