   ::= { sm8tat2saARPInspection 1 }

sm8tat2saARPPortConfigTable OBJECT-TYPE
   SYNTAX SEQUENCE OF SM8TAT2SAARPPortConfigEntry
   MAX-ACCESS not-accessible
   STATUS current
   DESCRIPTION
      "The ARP Port Configuration Table."
   ::= { sm8tat2saARPInspection 2 }

sm8tat2saARPPortConfigEntry OBJECT-TYPE
   SYNTAX SM8TAT2SAARPPortConfigEntry
   MAX-ACCESS not-accessible
   STATUS current
   DESCRIPTION
      "The ARP Port Configuration Entry."
   INDEX { ifIndex }
   ::= { sm8tat2saARPPortConfigTable 1 }

SM8TAT2SAARPPortConfigEntry ::= SEQUENCE {
   sm8tat2saARPPortConfigMode AdminMode,
   sm8tat2saARPPortConfigCheckVLAN AdminMode,
   sm8tat2saARPPortConfigLogType INTEGER
}

sm8tat2saARPPortConfigMode OBJECT-TYPE
   SYNTAX AdminMode
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
      "Specify ARP Inspection is enabled on which ports."
   ::= { sm8tat2saARPPortConfigEntry 1 }

sm8tat2saARPPortConfigCheckVLAN OBJECT-TYPE
   SYNTAX AdminMode
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
      "When the setting of 'Check VLAN' is disabled, the log type of ARP Inspection will refer to the port setting.
       And the setting of 'Check VLAN' is enabled, the log type of ARP Inspection will refer to the VLAN setting."
   ::= { sm8tat2saARPPortConfigEntry 2 }

sm8tat2saARPPortConfigLogType OBJECT-TYPE
   SYNTAX INTEGER { none(0), deny(1), permit(2), all(3) }
   MAX-ACCESS read-write
   STATUS current
   DESCRIPTION
      "The log type of ARP Inspection will refer to the port setting.
       0: none,
       1: deny,
       2: permit,
       3: all,
       range: 0-3."
   ::= { sm8tat2saARPPortConfigEntry 3 }

sm8tat2saARPVlanConfigTable OBJECT-TYPE
   SYNTAX SEQUENCE OF SM8TAT2SAARPVlanConfigEntry
   MAX-ACCESS not-accessible
   STATUS current
