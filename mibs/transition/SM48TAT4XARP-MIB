--sm48tat4xarpQosPortPolicingTable
   sm48tat4xarpQosPortPolicingTable OBJECT-TYPE
               SYNTAX      SEQUENCE OF     SM48TAT4XARPQosPortPolicingEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "The Policer settings.
                    INDEX for this table is ifIndex which is
                    equivalent to the panel port number."
               ::= {     sm48tat4xarpQosPortPolicing 1 }

    sm48tat4xarpQosPortPolicingEntry OBJECT-TYPE
               SYNTAX          SM48TAT4XARPQosPortPolicingEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "The Policer setting entry."
               INDEX    {     ifIndex  }
               ::= {     sm48tat4xarpQosPortPolicingTable 1 }

    SM48TAT4XARPQosPortPolicingEntry             ::= SEQUENCE {
                sm48tat4xarpQosPortPolicingEnabled         AdminMode,
                sm48tat4xarpQosPortPolicingRate            Integer32,
                sm48tat4xarpQosPortPolicingUnit            Integer32,
                sm48tat4xarpQosPortPolicingFlowControl     AdminMode
                }

    sm48tat4xarpQosPortPolicingEnabled OBJECT-TYPE
               SYNTAX      AdminMode
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Controls whether the policer is enabled on this switch port."
               DEFVAL  { disable }
               ::= {     sm48tat4xarpQosPortPolicingEntry 2 }

    sm48tat4xarpQosPortPolicingRate OBJECT-TYPE
               SYNTAX      Integer32
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "Controls the rate for the policer.
                    default: 500(kbps)."
               ::= {     sm48tat4xarpQosPortPolicingEntry 3 }

    sm48tat4xarpQosPortPolicingUnit OBJECT-TYPE
               SYNTAX      Integer32
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "Controls the unit of measure for the policer rate.
                    0: kbps
                    1: Mbps
		    2: fps
		    3: kfps
		    "
               ::= {     sm48tat4xarpQosPortPolicingEntry 4 }

    sm48tat4xarpQosPortPolicingFlowControl OBJECT-TYPE
               SYNTAX      AdminMode
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "If flow control is enabled and the port is in flow control mode,
                    then pause frames are sent instead of discarding frames."
               DEFVAL  { disable }
               ::= {     sm48tat4xarpQosPortPolicingEntry 5 }

