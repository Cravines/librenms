-- Start sm48tat4xarpQosPortClassification group
-- =======================================================================================================================
--sm48tat4xarpQosPortClassificationTable

     sm48tat4xarpQosPortClassificationTable OBJECT-TYPE
               SYNTAX      SEQUENCE OF     SM48TAT4XARPQosPortClassificationEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "QoS Ingress Port Classification.
                    INDEX for this table is ifIndex which is
                    equivalent to the panel port number."
               ::= {     sm48tat4xarpQosPortClassification  1 }

    sm48tat4xarpQosPortClassificationEntry OBJECT-TYPE
               SYNTAX          SM48TAT4XARPQosPortClassificationEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "The Qos Port Classification Table."
               INDEX    {     ifIndex  }
               ::= {     sm48tat4xarpQosPortClassificationTable 1 }

    SM48TAT4XARPQosPortClassificationEntry             ::= SEQUENCE {
                sm48tat4xarpQosPortClassificationQoSClass        Integer32,
                sm48tat4xarpQosPortClassificationDPlevel         Integer32,
                sm48tat4xarpQosPortClassificationPCP             Integer32,
                sm48tat4xarpQosPortClassificationDEI             Integer32,
                sm48tat4xarpQosPortClassificationPCPClassification AdminMode,
                sm48tat4xarpQosPortClassificationDSCPBased       AdminMode,
--              sm48tat4xarpQosPortClassificationQCLAddr         INTEGER,
--              sm48tat4xarpQosPortClassificationKeyType         KeyType,
                sm48tat4xarpQosPortClassificationWredGroup       Integer32
                }

    sm48tat4xarpQosPortClassificationQoSClass OBJECT-TYPE
               SYNTAX      Integer32(0..7)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Controls the default QoS class, i.e., the QoS class for
                   frames not classified
                   in any way. There is a one to one mapping between
                   QoS class, queue and
                   priority. A QoS class of 0 (zero) has the lowest priority.
                   NOTe: If the QoS class has been dynamically changed, then
                   the actual QoS class
                   is shown in parentheses after the configured QoS class.
                   range: 0~7,
                   default: 0."
               ::= {     sm48tat4xarpQosPortClassificationEntry 2 }

    sm48tat4xarpQosPortClassificationDPlevel OBJECT-TYPE
               SYNTAX      Integer32(0..3)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "DP level for frames not classified in any way.
                    range: 0~3,
                    default: 0."
               ::= {     sm48tat4xarpQosPortClassificationEntry 3 }

    sm48tat4xarpQosPortClassificationPCP OBJECT-TYPE
               SYNTAX      Integer32(0..7)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Priority Code Point. It is a 3-bit field storing
                   the priority level for the 802.1Q frame.
                   range: 0~7,
                   default: 0.
                   "
               ::= {     sm48tat4xarpQosPortClassificationEntry 4 }

    sm48tat4xarpQosPortClassificationDEI OBJECT-TYPE
               SYNTAX      Integer32(0|1)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Drop Eligible Indicator. It is a 1-bit field in the VLAN.
                   range 0~1,
                   default: 0.
                  "
               ::= {     sm48tat4xarpQosPortClassificationEntry 5 }

    sm48tat4xarpQosPortClassificationPCPClassification OBJECT-TYPE
               SYNTAX      AdminMode
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Configure the classification mode for tagged frames.
                  "
               DEFVAL  { disable }
               ::= {     sm48tat4xarpQosPortClassificationEntry 6 }

    sm48tat4xarpQosPortClassificationDSCPBased OBJECT-TYPE
               SYNTAX      AdminMode
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Click to Enable DSCP Based QoS Ingress Port Classification."
               DEFVAL  { disable }
               ::= {     sm48tat4xarpQosPortClassificationEntry 7 }

--    sm48tat4xarpQosPortClassificationQCLAddr OBJECT-TYPE
--               SYNTAX      INTEGER { sMacSip(0), dMacDip (1) }
--               MAX-ACCESS  read-write
--               STATUS      current
--               DESCRIPTION
--                  "Controls the QCL address matching mode.
--                   0: SMAC/SIP,
--                   1: DMAC/DIP,
--                  default: SMAC/SIP.
--                  Only support SPARX_III."
--               DEFVAL  { sMacSip }
--               ::= {     sm48tat4xarpQosPortClassificationEntry 8 }

--    sm48tat4xarpQosPortClassificationKeyType OBJECT-TYPE
--               SYNTAX      KeyType
--               MAX-ACCESS  read-write
--               STATUS      current
--               DESCRIPTION
--                  "The key type specifying the key generated for frames received
--                   on the port.
--                   0: Normal, Half key, match outer tag, SIP/DIP and SMAC/DMAC.
--                   1: Double Tag: Quarter key, match inner and outer tag.
--                   2: IP Address: Half key, match inner and outer tag, SIP and
--                      DIP. For non-IP frames, match outer tag only.
--                   3: MAC and IP Address: Full key, match inner and outer tag,
--                      SMAC, DMAC, SIP and DIP.
--                   Only support on SERVAL version."
--               DEFVAL  { normal }
--               ::= {     sm48tat4xarpQosPortClassificationEntry 9 }

    sm48tat4xarpQosPortClassificationWredGroup OBJECT-TYPE
               SYNTAX      Integer32
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                  "Controls the WRED group membership. Range:1-3."
               ::= {     sm48tat4xarpQosPortClassificationEntry 10 }

--sm48tat4xarpQoSIngressPortTagClassificationTable
    sm48tat4xarpQoSIngressPortTagClassificationTable OBJECT-TYPE
               SYNTAX      SEQUENCE OF     SM48TAT4XARPQoSIngressPortTagClassificationEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "Show QoS Ingress Port Tag Classification.
                    INDEX for this table is ifIndex which is
                    equivalent to the panel port number."
               ::= {     sm48tat4xarpQosPortClassification 2 }

    sm48tat4xarpQoSIngressPortTagClassificationEntry OBJECT-TYPE
               SYNTAX          SM48TAT4XARPQoSIngressPortTagClassificationEntry
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "QoS Ingress Port Tag Classification entry."
               INDEX    {     ifIndex,
                              sm48tat4xarpQoSIngressPortTagPCP,
                              sm48tat4xarpQoSIngressPortTagDEI  }
               ::= {     sm48tat4xarpQoSIngressPortTagClassificationTable 1 }

    SM48TAT4XARPQoSIngressPortTagClassificationEntry             ::= SEQUENCE {
                sm48tat4xarpQoSIngressPortTagPCP                   INTEGER,
                sm48tat4xarpQoSIngressPortTagDEI                   INTEGER,
                sm48tat4xarpQoSIngressPortTagQosClass              Integer32,
                sm48tat4xarpQoSIngressPortTagDPLevel               Integer32
                }

    sm48tat4xarpQoSIngressPortTagPCP OBJECT-TYPE
               SYNTAX      INTEGER { pcp0(1),
                                     pcp1(2),
                                     pcp2(3),
                                     pcp3(4),
                                     pcp4(5),
                                     pcp5(6),
                                     pcp6(7),
                                     pcp7(8) }
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "range: 1-8,
                    PCP0:1, PCP1:2..."
               ::= {     sm48tat4xarpQoSIngressPortTagClassificationEntry 2 }

    sm48tat4xarpQoSIngressPortTagDEI OBJECT-TYPE
               SYNTAX      INTEGER { dei0(1), dei1(2) }
               MAX-ACCESS  not-accessible
               STATUS      current
               DESCRIPTION
                   "Ingress Port Tag dei,
                    DEI0:1, DEI1:2."
               ::= {     sm48tat4xarpQoSIngressPortTagClassificationEntry 3 }

    sm48tat4xarpQoSIngressPortTagQosClass OBJECT-TYPE
               SYNTAX      Integer32(0..7)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "range: 0-7."
               ::= {     sm48tat4xarpQoSIngressPortTagClassificationEntry 4 }

    sm48tat4xarpQoSIngressPortTagDPLevel OBJECT-TYPE
               SYNTAX      Integer32(0..3)
               MAX-ACCESS  read-write
               STATUS      current
               DESCRIPTION
                   "range: 0-3."
               ::= {     sm48tat4xarpQoSIngressPortTagClassificationEntry 5 }


